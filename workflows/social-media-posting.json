{
  "name": "Social Media Media Posting Workflow",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "platform-id",
              "name": "platform",
              "value": "instagram",
              "type": "string"
            },
            {
              "id": "media-url-id",
              "name": "mediaUrl",
              "value": "https://example.com/image.jpg",
              "type": "string"
            },
            {
              "id": "media-type-id",
              "name": "mediaType",
              "value": "IMAGE",
              "type": "string"
            },
            {
              "id": "caption-id",
              "name": "caption",
              "value": "Check out this AI generated content!",
              "type": "string"
            },
            {
              "id": "account-id",
              "name": "accountId",
              "value": "YOUR_IG_USER_ID",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-metadata",
      "name": "Set Metadata",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [320, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "value": "instagram",
              "output": 0
            },
            {
              "value": "x",
              "output": 1
            },
            {
              "value": "tiktok",
              "output": 2
            }
          ]
        }
      },
      "id": "platform-switch",
      "name": "Switch Platform",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [540, 300],
      "renameNext": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $json.accountId }}/media",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "caption",
              "value": "={{ $json.caption }}"
            },
            {
              "name": "image_url",
              "value": "={{ $json.mediaType === 'IMAGE' ? $json.mediaUrl : undefined }}"
            },
            {
              "name": "video_url",
              "value": "={{ $json.mediaType === 'VIDEO' ? $json.mediaUrl : undefined }}"
            },
            {
              "name": "media_type",
              "value": "={{ $json.mediaType === 'VIDEO' ? 'REELS' : undefined }}"
            }
          ]
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "ig-create-container",
      "name": "Instagram: Create Container",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [800, 150]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $node[\"Set Metadata\"].json.accountId }}/media_publish",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "creation_id",
              "value": "={{ $json.id }}"
            }
          ]
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "ig-publish",
      "name": "Instagram: Publish",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 150]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://upload.twitter.com/1.1/media/upload.json",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "media",
              "value": "={{ $json.mediaUrl }}",
              "parameterType": "formBinaryData"
            }
          ]
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth1Api",
        "options": {}
      },
      "id": "x-upload-media",
      "name": "X: Upload Media",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [700, 300]
    },
    {
      "parameters": {
        "resource": "tweet",
        "text": "={{ $node[\"Set Metadata\"].json.caption }}",
        "additionalFields": {
          "attachments": "={{ $json.media_id_string }}"
        }
      },
      "id": "x-post",
      "name": "X: Post Tweet",
      "type": "n8n-nodes-base.twitter",
      "typeVersion": 2,
      "position": [950, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://open.tiktokapis.com/v2/post/publish/video/init/",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "source_info",
              "value": "={{ { source: 'PULL_FROM_URL', video_url: $json.mediaUrl } }}"
            },
            {
              "name": "post_info",
              "value": "={{ { title: $json.caption, description: $json.caption } }}"
            }
          ]
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "tiktok-post",
      "name": "TikTok: Post Video",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [800, 450]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Set Metadata",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Metadata": {
      "main": [
        [
          {
            "node": "platform-switch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "platform-switch": {
      "main": [
        [
          {
            "node": "ig-create-container",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "x-upload-media",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "tiktok-post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ig-create-container": {
      "main": [
        [
          {
            "node": "ig-publish",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "x-upload-media": {
      "main": [
        [
          {
            "node": "x-post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
